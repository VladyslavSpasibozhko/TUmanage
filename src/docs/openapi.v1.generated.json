{
  "openapi": "3.1.0",
  "info": {
    "title": "API",
    "version": "v1"
  },
  "paths": {
    "/v1/login": {
      "post": {
        "summary": "Login",
        "description": "Authenticates an existing user by email and password and creates a new session. Multiple concurrent sessions per user are allowed. Failure is generic (\"Invalid email or password\") regardless of whether the email exists or the password is wrong.",
        "responses": {
          "200": {
            "description": "HTTP 200",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "success": {
                          "const": true
                        },
                        "data": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "userId": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "expiredAt": {
                              "type": "number"
                            }
                          },
                          "required": [
                            "id",
                            "userId",
                            "expiredAt"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "success",
                        "data"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "success": {
                          "const": false
                        },
                        "err": {
                          "type": "object",
                          "properties": {
                            "code": {
                              "type": "number"
                            },
                            "err": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "code",
                            "err"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "success",
                        "err"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  }
                },
                "required": [
                  "email",
                  "password"
                ],
                "additionalProperties": false
              }
            }
          }
        }
      }
    },
    "/v1/logout": {
      "post": {
        "summary": "Logout",
        "description": "Ends the current session (the one identified by the request's session cookie). Idempotent: if no session cookie is present, or the session was already deleted, it still responds as a success.",
        "responses": {
          "200": {
            "description": "HTTP 200",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "success": {
                          "const": true
                        },
                        "data": {
                          "const": null
                        }
                      },
                      "required": [
                        "success",
                        "data"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "success": {
                          "const": false
                        },
                        "err": {
                          "type": "object",
                          "properties": {
                            "code": {
                              "type": "number"
                            },
                            "err": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "code",
                            "err"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "success",
                        "err"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/register": {
      "post": {
        "summary": "Register",
        "description": "Creates a new Credential (email + password) and a new User, then immediately logs the user in by creating a session. Email is not verified before login.",
        "responses": {
          "200": {
            "description": "HTTP 200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "const": false
                    },
                    "err": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "number"
                        },
                        "err": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "code",
                        "err"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "success",
                    "err"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "201": {
            "description": "HTTP 201",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "const": true
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "format": "uuid"
                        },
                        "userId": {
                          "type": "string",
                          "format": "uuid"
                        },
                        "expiredAt": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "id",
                        "userId",
                        "expiredAt"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "success",
                    "data"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 12
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  }
                },
                "required": [
                  "name",
                  "email",
                  "password"
                ],
                "additionalProperties": false
              }
            }
          }
        }
      }
    },
    "/v1/session/refresh": {
      "post": {
        "summary": "Refresh Session",
        "description": "Extends the expiry of the currently active session (identified by the request's session cookie). An expired or missing session cannot be refreshed and requires logging in again.",
        "responses": {
          "200": {
            "description": "HTTP 200",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "success": {
                          "const": true
                        },
                        "data": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "userId": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "expiredAt": {
                              "type": "number"
                            }
                          },
                          "required": [
                            "id",
                            "userId",
                            "expiredAt"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "success",
                        "data"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "success": {
                          "const": false
                        },
                        "err": {
                          "type": "object",
                          "properties": {
                            "code": {
                              "type": "number"
                            },
                            "err": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "code",
                            "err"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "success",
                        "err"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "HTTP 401",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "const": false
                    },
                    "err": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "const": 401
                        },
                        "err": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "code",
                        "err"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "success",
                    "err"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    }
  }
}
