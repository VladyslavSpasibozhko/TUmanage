{
  "title": "Register",
  "path": "/api/register",
  "method": "POST",
  "description": "Creates a new Credential (email + password) and a new User, then immediately logs the user in by creating a session. Email is not verified before login.",
  "input": {
    "type": "object",
    "properties": {
      "name": { "type": "string", "minLength": 2, "maxLength": 12 },
      "email": { "type": "string", "format": "email" },
      "password": { "type": "string", "minLength": 8 }
    },
    "required": ["name", "email", "password"],
    "additionalProperties": false
  },
  "output": {
    "201": {
      "type": "object",
      "properties": {
        "success": { "const": true },
        "data": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "userId": { "type": "string", "format": "uuid" },
            "expiredAt": { "type": "number" }
          },
          "required": ["id", "userId", "expiredAt"],
          "additionalProperties": false
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    "200": {
      "type": "object",
      "properties": {
        "success": { "const": false },
        "err": {
          "type": "object",
          "properties": {
            "code": { "type": "number" },
            "err": { "type": "string" }
          },
          "required": ["code", "err"],
          "additionalProperties": false
        }
      },
      "required": ["success", "err"],
      "additionalProperties": false
    }
  }
}
