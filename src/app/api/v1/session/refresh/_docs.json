{
  "title": "Refresh Session",
  "path": "/v1/session/refresh",
  "method": "POST",
  "description": "Extends the expiry of the currently active session (identified by the request's session cookie). An expired or missing session cannot be refreshed and requires logging in again.",
  "input": null,
  "output": {
    "200": {
      "type": "object",
      "properties": {
        "success": { "const": true },
        "data": { "$ref": "@/src/domain/session/schema.ts#sessionSchema" }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    "401": {
      "type": "object",
      "properties": {
        "success": { "const": false },
        "err": {
          "type": "object",
          "properties": {
            "code": { "const": 401 },
            "err": { "type": "string" }
          },
          "required": ["code", "err"],
          "additionalProperties": false
        }
      },
      "required": ["success", "err"],
      "additionalProperties": false
    },
    "500": {
      "type": "object",
      "properties": {
        "success": { "const": false },
        "err": {
          "type": "object",
          "properties": {
            "code": { "const": 500 },
            "err": { "type": "string" }
          },
          "required": ["code", "err"],
          "additionalProperties": false
        }
      },
      "required": ["success", "err"],
      "additionalProperties": false
    }
  }
}
