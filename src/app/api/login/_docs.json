{
  "title": "Login",
  "path": "/api/login",
  "method": "POST",
  "description": "Authenticates an existing user by email and password and creates a new session. Multiple concurrent sessions per user are allowed. Failure is generic (\"Invalid email or password\") regardless of whether the email exists or the password is wrong.",
  "input": {
    "type": "object",
    "properties": {
      "email": { "type": "string", "format": "email" },
      "password": { "type": "string", "minLength": 8 }
    },
    "required": ["email", "password"],
    "additionalProperties": false
  },
  "output": {
    "200": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "success": { "const": true },
            "data": {
              "type": "object",
              "properties": {
                "id": { "type": "string", "format": "uuid" },
                "userId": { "type": "string", "format": "uuid" },
                "expiredAt": { "type": "number" }
              },
              "required": ["id", "userId", "expiredAt"],
              "additionalProperties": false
            }
          },
          "required": ["success", "data"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "success": { "const": false },
            "err": {
              "type": "object",
              "properties": {
                "code": { "type": "number" },
                "err": { "type": "string" }
              },
              "required": ["code", "err"],
              "additionalProperties": false
            }
          },
          "required": ["success", "err"],
          "additionalProperties": false
        }
      ]
    }
  }
}
